rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Users doc — kendi profili, isPublic profiller veya admin okuyabilir
    match /users/{uid} {
      allow read: if request.auth != null &&
        (request.auth.uid == uid ||
         (resource != null && resource.data.isPublic == true) ||
         isAdmin());
      allow write: if request.auth != null && (request.auth.uid == uid || isAdmin());
    }

    // Username uniqueness check (onboarding) — authenticated users can list
    match /users {
      allow list: if request.auth != null;
    }

    // Trades subcollection — sahibi veya admin
    match /users/{uid}/trades/{tradeId} {
      allow read, write: if request.auth != null && (request.auth.uid == uid || isAdmin());
    }

    // Strategies — giriş yapmış herkes okuyabilir; oluşturan veya admin yazabilir
    match /strategies/{strategyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (request.auth.uid == request.resource.data.createdBy || isAdmin());
      allow update, delete: if request.auth != null && (request.auth.uid == resource.data.createdBy || isAdmin());
    }

    // Leaderboard — herkes (anonim dahil) okuyabilir; sahibi veya admin yazabilir
    match /leaderboard/{period}/entries/{uid} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.uid == uid || isAdmin());
    }

    // Conversations — katılımcı okuyabilir, topluluk/ açık grup herkes okuyabilir
    match /conversations/{conversationId} {
      allow read: if request.auth != null && (
        resource.data.participants.hasAny([request.auth.uid]) ||
        resource.data.type == "community" ||
        (resource.data.groupType == "open" && resource.data.type == "group")
      );
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        resource.data.ownerId == request.auth.uid ||
        resource.data.participants.hasAny([request.auth.uid])
      );
      allow delete: if isAdmin();
    }

    // Messages — conversation'a erişimi olan herkes okuyabilir, katılımcı yazabilir
    match /conversations/{conversationId}/messages/{messageId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants.hasAny([request.auth.uid]);
      allow delete: if isAdmin();
    }

    // Read status — sadece kendi okuma durumunu görebilir
    match /conversations/{conversationId}/readStatus/{uid} {
      allow read, write: if request.auth.uid == uid;
    }
  }
}
