rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users doc — giriş yapmış herkes okuyabilir; yalnızca sahibi yazabilir
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Username uniqueness check (onboarding) — authenticated users can list
    match /users {
      allow list: if request.auth != null;
    }

    // Trades subcollection — sadece sahibi
    match /users/{uid}/trades/{tradeId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Strategies — giriş yapmış herkes okuyabilir; yalnızca oluşturan yazabilir
    match /strategies/{strategyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.createdBy;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.createdBy;
    }

    // Leaderboard — herkes (anonim dahil) okuyabilir; yalnızca sahibi yazabilir
    match /leaderboard/{period}/entries/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
