rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isConversationMember() {
      return resource.data.participants.hasAny([request.auth.uid]) ||
             resource.data.type == "community" ||
             (resource.data.groupType == "open" && resource.data.type == "group");
    }

    function isConversationMemberById(conversationId) {
      let conv = get(/databases/$(database)/documents/conversations/$(conversationId)).data;
      return conv != null && (
        conv.participants.hasAny([request.auth.uid]) ||
        conv.type == "community" ||
        (conv.groupType == "open" && conv.type == "group")
      );
    }

    // Users doc — sadece sahibi veya admin okuyabilir/yazabilir
    match /users/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow write: if request.auth != null && (request.auth.uid == uid || isAdmin());
    }

    // Public profiles — giriş yapmış herkes okuyabilir (arama için), sahibi yazabilir
    match /publicProfiles/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Trades subcollection — sahibi veya admin
    match /users/{uid}/trades/{tradeId} {
      allow read, write: if request.auth != null && (request.auth.uid == uid || isAdmin());
    }

    // Strategies — public olanlar herkes, private olanlar sadece sahibi veya admin okuyabilir
    match /strategies/{strategyId} {
      allow read: if request.auth != null && (
        resource.data.isPublic == true ||
        resource.data.createdBy == request.auth.uid ||
        isAdmin()
      );
      allow create: if request.auth != null && (request.auth.uid == request.resource.data.createdBy || isAdmin());
      allow update, delete: if request.auth != null && (request.auth.uid == resource.data.createdBy || isAdmin());
    }

    // Leaderboard — herkes (anonim dahil) okuyabilir; sadece admin yazabilir
    // Skorlar Cloud Function tarafından trade verisinden hesaplanıp yazılmalı,
    // client'tan direkt yazma kapatıldı.
    match /leaderboard/{period}/entries/{uid} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Conversations — katılımcı okuyabilir, topluluk/ açık grup herkes okuyabilir
    match /conversations/{conversationId} {
      allow read: if request.auth != null && isConversationMember();
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        resource.data.ownerId == request.auth.uid ||
        resource.data.participants.hasAny([request.auth.uid])
      );
      allow delete: if isAdmin();
    }

    // Messages — conversation üyesi okuyabilir ve yazabilir
    match /conversations/{conversationId}/messages/{messageId} {
      allow read: if request.auth != null && isConversationMemberById(conversationId);
      allow create: if request.auth != null && isConversationMemberById(conversationId);
      allow delete: if isAdmin();
    }

    // Read status — sadece kendi okuma durumunu görebilir
    match /conversations/{conversationId}/readStatus/{uid} {
      allow read, write: if request.auth.uid == uid;
    }

    // Invitations — davet edilen kişi okuyabilir, davet eden oluşturabilir
    match /invitations/{invitationId} {
      allow read: if request.auth != null && (
        resource.data.inviteeId == request.auth.uid ||
        resource.data.inviterId == request.auth.uid
      );
      allow create: if request.auth != null &&
        request.resource.data.inviterId == request.auth.uid &&
        request.resource.data.inviteeId != request.auth.uid;
      allow update: if request.auth != null && (
        (resource.data.inviteeId == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['status', 'respondedAt'])) ||
        (resource.data.inviterId == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['status']) &&
         resource.data.status == 'pending')
      );
      allow delete: if request.auth != null && (
        resource.data.inviterId == request.auth.uid ||
        resource.data.inviteeId == request.auth.uid
      );
    }
  }
}
